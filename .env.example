# =============================================
# CAPTA PROSPECT - Variáveis de Ambiente
# =============================================
# INSTRUÇÃO: Copie este arquivo, renomeie para .env
# e preencha com suas chaves reais.
# =============================================

# --- BACKEND ---
PORT=3006

# --- GEMINI AI (Qualificação de Leads) ---
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=SUA_CHAVE_GEMINI_AQUI

# --- GOOGLE MAPS API (Mineração de Empresas) ---
# Obtenha em: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=SUA_CHAVE_GOOGLE_MAPS_AQUI

# --- CONVEX (Banco de Dados em Nuvem) ---
# Já configurado pelo desenvolvedor. Não altere.
CONVEX_DEPLOYMENT=accurate-tiger-693
